# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real credentials.

# Gmail SMTP (use an App Password, not your normal password)
# https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here

# Your "Send to Kindle" email (Amazon → Manage Content and Devices → Preferences)
KINDLE_EMAIL=your_kindle@kindle.com
